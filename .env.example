# Ollama runs locally by default. Change this only for a different host/port.
OLLAMA_BASE_URL=http://localhost:11434
# -1 keeps models resident until Ollama is stopped. Use 30m to release memory
# after inactivity instead.
OLLAMA_KEEP_ALIVE=-1

# API binding and optional browser origins. Keep 127.0.0.1 for local-only use.
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated, for example: http://localhost:3000,http://localhost:5173
API_CORS_ORIGINS=

# MySQL source for ads ingestion.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rag_ht_test
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_TABLE=ads_search_ready
MYSQL_CONTENT_COLUMN=embedding_content
MYSQL_BM25_COLUMN=bm25_content
MYSQL_SEARCH_ID_COLUMN=id

# Canonical product rows returned after semantic retrieval and reranking.
MYSQL_RESULT_TABLE=ads
MYSQL_RESULT_ID_COLUMN=id
