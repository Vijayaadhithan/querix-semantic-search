# Ollama runs locally by default. Change this only for a different host/port.
OLLAMA_BASE_URL=http://localhost:11434
# -1 keeps models resident until Ollama is stopped. Use 30m to release memory
# after inactivity instead.
OLLAMA_KEEP_ALIVE=-1

# Hosted structured query extraction. Put real keys in .env.keys.
# Optional override for proxies or future Gemini API versions.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Per-model query-planning timeout before advancing to the next model.
GEMINI_TIMEOUT_SECONDS=10

# Local reranking default. Keep provider secrets only in .env.keys.
# To re-enable hosted fallback, use local,jina,voyage-2.5,voyage-2.5-lite.
RERANK_PROVIDER_ORDER=local
RERANK_API_TIMEOUT_SECONDS=5
RERANK_MAX_DOCUMENT_CHARS=800
# Good 8 GB CPU baseline: Apache-2.0, 149M params, no hosted API.
RERANK_LOCAL_MODEL=Alibaba-NLP/gte-reranker-modernbert-base
RERANK_LOCAL_ADAPTER=cross-encoder
RERANK_LOCAL_TRUST_REMOTE_CODE=false
# Fastest local fallback if the 149M model is still too slow:
# RERANK_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
# Multilingual quality benchmark candidate:
# RERANK_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
# Jina v3 benchmark example after license/code review only:
# RERANK_PROVIDER_ORDER=local,jina,voyage-2.5,voyage-2.5-lite
# RERANK_LOCAL_MODEL=jinaai/jina-reranker-v3
# RERANK_LOCAL_ADAPTER=jina-listwise
# RERANK_LOCAL_TRUST_REMOTE_CODE=true
VOYAGE_RERANK_URL=https://api.voyageai.com/v1/rerank
VOYAGE_RERANK_MODEL=rerank-2.5
VOYAGE_RERANK_LITE_MODEL=rerank-2.5-lite
# This account currently allows three requests per minute for each model.
VOYAGE_RERANK_RPM_PER_MODEL=3
JINA_RERANK_URL=https://api.jina.ai/v1/rerank
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# Shared query-plan cache. Search continues with process memory if unavailable.
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=semantic_ads
REDIS_RESULT_CACHE_ENABLED=true
REDIS_RESULT_CACHE_TTL_SECONDS=300

# API binding and optional browser origins. Keep 127.0.0.1 for local-only use.
API_HOST=127.0.0.1
API_PORT=8000
# info shows model selection and each search stage; debug is more verbose.
API_LOG_LEVEL=info
# Keep false only for the backward-compatible local single-company mode.
# Production must enable this and set the API key referenced by each tenant
# profile under configs/tenants/.
API_AUTH_ENABLED=false
API_RATE_LIMIT_ENABLED=true
# Separate key for /api/v1/{company}/admin/status. Leave blank to disable it.
API_TENANT_CONFIG_DIR=configs/tenants
API_TENANT_ENGINE_CACHE_SIZE=1
API_TENANT_MAX_CONCURRENT_SEARCHES=2
USAGE_TRACKING_ENABLED=true
USAGE_DB_PATH=storage/usage.sqlite3
# Comma-separated, for example: http://localhost:3000,http://localhost:5173
API_CORS_ORIGINS=

# Optional semantic latency benchmark knobs. Restart the API after changing.
# Test 30, 40, and 60 before changing production defaults.
# VECTOR_TOP_K=30
# BM25_TOP_K=30
# HYBRID_CANDIDATE_K=60
# RERANK_CANDIDATE_K=60
# PRIMARY_RANKED_K=60

# MySQL source for ads ingestion.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rag_ht_test
MYSQL_USER=
# Local MySQL testing can use disable. Production doctor expects verify-full
# plus cert paths in .env.keys.
GAINR_DB_TLS_MODE=disable
MYSQL_TABLE=ads_search_ready
MYSQL_CONTENT_COLUMN=embedding_content
MYSQL_BM25_COLUMN=bm25_content
MYSQL_SEARCH_ID_COLUMN=id

# Canonical product rows returned after semantic retrieval and reranking.
MYSQL_RESULT_TABLE=ads
MYSQL_RESULT_ID_COLUMN=id

# Example PostgreSQL company/source database variables. Tenant profiles may use
# company-prefixed names instead.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_TLS_CA_FILE=
POSTGRES_TLS_CERT_FILE=
POSTGRES_TLS_KEY_FILE=

# Dedicated PostgreSQL/pgvector database for vectors. BM25 remains SQLite.
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=rag_workbench
