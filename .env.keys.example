# Copy to .env.keys and keep real secrets only there.
# .env.keys is loaded after .env and overrides empty placeholder values.

# Hosted query planning.
GEMINI_API_KEY=
GROQ_API_KEY=

# Hosted reranking providers.
JINA_API_KEY=
VOYAGE_API_KEY=

# Company API keys. Each tenant profile lists the env names under api.key_envs.
GAINR_API_KEY=
# ACME_API_KEY=

# Protected admin endpoints.
API_ADMIN_KEY=

# Gainr MySQL credentials.
MYSQL_USER=
MYSQL_PASSWORD=

# Optional database TLS private-key material paths.
# Prefer GAINR_DB_TLS_MODE=verify-full in production and set these. If the
# provider cannot supply a CA/hostname, use GAINR_DB_TLS_MODE=require in .env
# as the encrypted fallback and leave the certificate paths empty.
GAINR_DB_TLS_CA_FILE=
GAINR_DB_TLS_CERT_FILE=
GAINR_DB_TLS_KEY_FILE=

# PostgreSQL credentials. For Docker's pgvector service, POSTGRES_USER and
# POSTGRES_PASSWORD are consumed by the Postgres image.
POSTGRES_USER=
POSTGRES_PASSWORD=

# Dedicated pgvector DB credentials used by the API tenant config. For the
# bundled Docker pgvector service, set these to the same values as POSTGRES_*.
PGVECTOR_USER=
PGVECTOR_PASSWORD=
